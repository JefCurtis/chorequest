#ifndef SECRETS_H
#define SECRETS_H

// ----- WiFi -----
#define WIFI_SSID       "your_wifi_ssid"
#define WIFI_PASSWORD   "your_wifi_password"

// ----- Todoist -----
// Get your API token from: todoist.com -> Settings -> Integrations -> Developer
// Project ID: found in the URL when viewing your project (the alphanumeric ID)
#define TODOIST_API_TOKEN  "your_todoist_api_token"
#define TODOIST_PROJECT_ID "your_project_id"

// ----- Personalization -----
#define USER_NAME          "Kid"        // Name shown in praise messages
#define TIMEZONE_OFFSET    -7           // UTC offset in hours (e.g., -7 for PDT, -5 for EST, 0 for UTC)
#define DST_OFFSET         1            // Daylight saving offset in hours (0 or 1)
#define WEEKLY_REWARD      "$10"        // Reward text for completing weekly chores

#endif
